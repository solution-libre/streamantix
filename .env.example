# Twitch credentials
TWITCH_TOKEN=oauth:your_token_here
TWITCH_CHANNEL=your_channel_name

# Bot configuration
COMMAND_PREFIX=!sx
COOLDOWN=5

# Game configuration
# Possible values: easy, medium, hard
DIFFICULTY=easy

# Path to the Word2Vec binary model file (relative to project root)
# Download with: python download_model.py
MODEL_PATH=models/frWac_no_postag_no_phrase_700_skip_cut50.bin

# Overlay configuration
# Set OVERLAY_ENABLED=true to start the web overlay alongside the bot
OVERLAY_ENABLED=false
OVERLAY_PORT=8080
