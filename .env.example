# Twitch credentials
# Option A – manual token (legacy, no OAuth flow required)
TWITCH_TOKEN=oauth:your_token_here

# Option B – OAuth Authorization Code flow (recommended)
# Leave TWITCH_TOKEN unset and fill in the three vars below instead.
TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=your_client_secret_here
TWITCH_REDIRECT_URI=http://localhost:4343/callback
TWITCH_SCOPES=chat:read chat:edit
TWITCH_TOKEN_PATH=.secrets/twitch_tokens.json

TWITCH_CHANNEL=your_channel_name

# Bot configuration
COMMAND_PREFIX=!sx
COOLDOWN=5

# Game configuration
# Possible values: easy, medium, hard
DIFFICULTY=easy

# Path to the Word2Vec binary model file (relative to project root)
# Download with: python download_model.py
MODEL_PATH=models/frWac_no_postag_no_phrase_700_skip_cut50.bin

# Overlay configuration
# Set OVERLAY_ENABLED=true to start the web overlay alongside the bot
OVERLAY_ENABLED=false
OVERLAY_PORT=8080
