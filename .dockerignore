# Models directory — downloaded at container startup, never baked in
models/

# Environment files — provided at runtime via --env-file or docker-compose
.env
.env.*

# Python caches and build artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/

# Test artifacts
.pytest_cache/
.coverage
coverage.xml
htmlcov/
tests/

# Version control
.git/
.gitignore

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
